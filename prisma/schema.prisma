generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Datos financieros del usuario
  transacciones  Transaccion[]
  presupuestos   PresupuestoCategoria[]
  deudas         Deuda[]
  activos        Activo[]
  metas          MetaFinanciera[]
  cuentas        Cuenta[]
  categorias     Categoria[]
  metodoPagos    MetodoPago[]
  configuracion  ConfiguracionFinanciera?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TipoMovimiento {
  INGRESO
  GASTO
  TRANSFERENCIA
}

enum TipoCuenta {
  EFECTIVO
  AHORRO
  CORRIENTE
  INVERSION
  CREDITO
}

enum TipoDeuda {
  DEUDA_PROPIA
  DEUDA_AJENA
}

enum TipoActivo {
  EFECTIVO
  INVERSION
  BIEN_RAIZ
  VEHICULO
  NEGOCIO
  OTRO
}

enum TipoMeta {
  AHORRO
  RETIRO
  EMERGENCIA
  VIAJE
  OTRO
}

enum EstrategiaDeuda {
  SNOWBALL
  AVALANCHE
}

// ─── Maestros (por usuario) ───────────────────────────────────────────────────

model Categoria {
  id            Int                    @id @default(autoincrement())
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre        String
  tipo          TipoMovimiento
  icono         String?
  color         String?
  transacciones Transaccion[]
  presupuestos  PresupuestoCategoria[]

  @@unique([userId, nombre])
}

model Cuenta {
  id            Int           @id @default(autoincrement())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre        String
  tipo          TipoCuenta
  saldoInicial  Float         @default(0)
  moneda        String        @default("COP")
  transacciones Transaccion[]

  @@unique([userId, nombre])
}

model MetodoPago {
  id            Int           @id @default(autoincrement())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre        String
  transacciones Transaccion[]

  @@unique([userId, nombre])
}

// ─── Core: Transacciones ─────────────────────────────────────────────────────

model Transaccion {
  id           Int            @id @default(autoincrement())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo         TipoMovimiento
  descripcion  String
  monto        Float
  fecha        DateTime       @default(now())
  categoriaId  Int
  categoria    Categoria      @relation(fields: [categoriaId], references: [id])
  cuentaId     Int?
  cuenta       Cuenta?        @relation(fields: [cuentaId], references: [id])
  metodoPagoId Int?
  metodoPago   MetodoPago?    @relation(fields: [metodoPagoId], references: [id])
  nota         String?
  createdAt    DateTime       @default(now())
}

// ─── Presupuesto mensual ──────────────────────────────────────────────────────

model PresupuestoCategoria {
  id          Int       @id @default(autoincrement())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mes         String
  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  monto       Float
  createdAt   DateTime  @default(now())

  @@unique([userId, mes, categoriaId])
}

// ─── Deudas ───────────────────────────────────────────────────────────────────

model Deuda {
  id               Int             @id @default(autoincrement())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre           String
  tipo             TipoDeuda
  montoOriginal    Float
  montoActual      Float
  tasaInteres      Float           @default(0)
  cuotaMensual     Float?
  fechaInicio      DateTime
  fechaVencimiento DateTime?
  estrategia       EstrategiaDeuda @default(AVALANCHE)
  pagos            PagoDeuda[]
  createdAt        DateTime        @default(now())
}

model PagoDeuda {
  id      Int      @id @default(autoincrement())
  deudaId Int
  deuda   Deuda    @relation(fields: [deudaId], references: [id], onDelete: Cascade)
  monto   Float
  fecha   DateTime @default(now())
  nota    String?
}

// ─── Activos ──────────────────────────────────────────────────────────────────

model Activo {
  id          Int               @id @default(autoincrement())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre      String
  tipo        TipoActivo
  valorActual Float
  historial   HistorialActivo[]
  createdAt   DateTime          @default(now())
}

model HistorialActivo {
  id       Int      @id @default(autoincrement())
  activoId Int
  activo   Activo   @relation(fields: [activoId], references: [id], onDelete: Cascade)
  valor    Float
  fecha    DateTime @default(now())
}

// ─── Metas financieras ────────────────────────────────────────────────────────

model MetaFinanciera {
  id          Int       @id @default(autoincrement())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre      String
  tipo        TipoMeta
  montoMeta   Float
  montoActual Float     @default(0)
  fechaMeta   DateTime?
  createdAt   DateTime  @default(now())
}

// ─── Configuración por usuario ────────────────────────────────────────────────

model ConfiguracionFinanciera {
  userId               String  @id
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombreUsuario        String  @default("Usuario")
  moneda               String  @default("COP")
  tasaRetornoEsperada  Float   @default(0.07)
  tasaInflacion        Float   @default(0.04)
  edadActual           Int?
  edadRetiro           Int?
  gastoMensualDeseado  Float?
}
